rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /telegram_users/{userId} {
      allow read, write: if true;
      match /watchlist/{symbol} {
        allow read, write: if true;
      }
      match /alerts/{alertId} {
        allow read, write: if true;
      }
    }
  }
}
